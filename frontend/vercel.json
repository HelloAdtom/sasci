{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://REPLACE-WITH-YOUR-RENDER-URL.onrender.com/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://REPLACE-WITH-YOUR-RENDER-URL.onrender.com/uploads/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
