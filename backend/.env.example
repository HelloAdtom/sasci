# Copy to .env for local development. Render sets these as real
# environment variables in production — it does not read this file.

# Local dev default matches docker-compose.yml at the repo root.
DATABASE_URL="postgresql://sasci:sasci@localhost:5432/sasci"

# Any long random string. Render: set a real generated value in its dashboard.
JWT_SECRET="sasci-dev-secret-change-in-production"

PORT=3001
